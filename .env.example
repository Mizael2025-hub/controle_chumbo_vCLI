# ============================================================
# .env.example — Plataforma PCP (Módulo: Controle de Chumbo)
# Copie para .env e ajuste os valores. NUNCA versione o .env real.
# ============================================================

# --- Django ---
DJANGO_SETTINGS_MODULE=core.settings
SECRET_KEY=django-insecure-troque-por-uma-chave-gerada-com-python-secrets
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Domínio de produção (Traefik/Cloudflare) — usado em SECURE_* e CSRF
# DOMAIN=pcp.exemplo.com.br

# --- Sessão (RF03: timeout por inatividade, 30 min padrão) ---
# Em segundos. 1800 = 30 min.
SESSION_IDLE_TIMEOUT=1800

# --- Banco de dados (PostgreSQL 16+) ---
# Em dev local sem Docker, deixe DATABASE_URL vazio/comentado
# para o settings cair em SQLite (PRD §9.2).
# Formato: postgres://USER:PASSWORD@HOST:PORT/NAME
DATABASE_URL=postgres://pcp:pcp@db:5432/komotores_pcp
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=komotores_pcp
POSTGRES_USER=pcp
POSTGRES_PASSWORD=pcp

# --- Filas (Celery + RabbitMQ) ---
CELERY_BROKER_URL=amqp://pcp:pcp@rabbitmq:5672/komotores_pcp

# --- Result backend / cache (Redis 7+) ---
CELERY_RESULT_BACKEND=django-db
REDIS_URL=redis://redis:6379/0
CACHE_URL=rediscache://redis:6379/1

# --- Filas padrão do Celery ---
CELERY_TASK_DEFAULT_QUEUE=komotores_pcp

# --- Email (dev: console; prod: SMTP) ---
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# EMAIL_HOST=smtp.exemplo.com.br
# EMAIL_PORT=587
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# EMAIL_USE_TLS=True
# DEFAULT_FROM_EMAIL=nao-responda@pcp.exemplo.com.br

# --- Seed (dados demo) ---
SEED_ADMIN_EMAIL=admin@komotores.local
SEED_ADMIN_PASSWORD=admin123456

# --- PWA ---
PWA_APP_NAME=Plataforma PCP
PWA_APP_SHORT_NAME=PCP

# ============================================================
# PRODUÇÃO (Docker Swarm + Traefik) — via docker secret/arquivo
# Não defina aqui em dev. Referência: PRD §9.3/§9.4.
# ============================================================
# CLOUDFLARE_DNS_API_TOKEN  -> docker secret (Traefik Let's Encrypt DNS-01)
# TRAEFIK_BASIC_AUTH         -> htpasswd hash (dashboard)
# GHCR_TOKEN                 -> CI/CD para push de imagem
